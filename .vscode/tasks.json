{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Restart Apache container",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"restart",
				"apache"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Rebuild Apache containers",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"up",
				"--build",
				"-d",
				"apache",
				"nginx"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Open Spotify dashboard",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Start-Process 'http://localhost:8585/spotify'"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Restart Apache and open Spotify",
			"dependsOrder": "sequence",
			"dependsOn": [
				"Restart Apache container",
				"Open Spotify dashboard"
			],
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}