# Optional: point the container at your albums folder on the host.# ALBUMS_DIR is already set in compose.yaml to /opt/albums.## Recommended on Windows: map the network share to a drive letter, then use that.#   net use Z: "\\Drgift\eti\+˙rMet"#   ALBUMS_HOST_PATH=Z:/## Alternative: copy/sync the share to a local folder and mount it.#   ALBUMS_HOST_PATH=D:/Apache/albums## If your Docker setup supports UNC mounts for Linux containers, this may work too:#   ALBUMS_HOST_PATH=//Drgift/eti/+˙rMet# Optional: mount Spotify account export folder into the app container.# Example (Windows path with spaces works in quotes in .env):# SPOTIFY_HOST_PATH="D:/spotify/my_spotify_data (2)/Spotify Account Data"# If not set, defaults to ./spotify-data# Optional: published host ports.# For public domain access without :port suffix, use 80/443.# HTTP_PORT=80# HTTPS_PORT=443# Optional direct Apache publish (normally keep behind nginx).# APACHE_PORT=8585# Optional: EasyDNS Dynamic DNS (updates a hostname to your current public IP).## EASYDNS_HOSTNAME=drsrv.net.ar# EASYDNS_USERNAME=your-easydns-username# EASYDNS_PASSWORD=your-easydns-password-or-token## Optional: override update server / interval.# EASYDNS_SERVER=members.easydns.com# EASYDNS_INTERVAL_SECONDS=300# Optional: media URL signing hardening (change in production)# MEDIA_SIGNING_KEY=replace-with-strong-random-secret# MEDIA_URL_TTL_SECONDS=300# Optional: base URL used to build hosted payment return links.# Set this when the app is reached through a public host or reverse proxy.# PUBLIC_BASE_URL=https://your-domain.example# Optional: Stripe hosted checkout# STRIPE_SECRET_KEY=sk_live_or_test_xxx# STRIPE_CURRENCY=usd# Optional: Mercado Pago hosted checkout# MERCADOPAGO_ACCESS_TOKEN=APP_USR-or-TEST-xxx# MERCADOPAGO_CURRENCY=USD# Optional: local Alpine OpenLDAP/LDAPS service# LDAP_PORT=389# LDAPS_PORT=636# LDAP_ORGANISATION=drsrv# LDAP_DOMAIN=drsrv.net.ar# LDAP_BASE_DN=DC=drsrv,DC=net,DC=ar# LDAP_ADMIN_PASSWORD=change-me-now# LDAP_TLS_CN=192.168.1.50# LDAP_DEFAULT_USER=carlo# LDAP_DEFAULT_PASSWORD=change-me-user-password# Optional: web app LDAP login (direct bind)# LDAP_SERVER_URL=ldaps://192.168.1.8:636# LDAP_BASE_DN=DC=drsrv,DC=net,DC=ar# LDAP_UPN_DOMAIN=drsrv.net.ar# LDAP_VALIDATE_CERTS=0# LDAP_CA_CERT_FILE=# Admin users - comma-separated usernames or emails that see the Spotify/Sync nav links# ADMIN_USERS=carlo,carlo@drsrv.net.ar# Optional: Microsoft Entra ID / OIDC SSO# Use either OIDC_TENANT_ID (recommended) or full OIDC_AUTHORITY.# OIDC_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx# OIDC_AUTHORITY=https://login.microsoftonline.com/<tenant-id>/v2.0# OIDC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx# OIDC_CLIENT_SECRET=your-client-secret# OIDC_REDIRECT_URI=https://your-domain/auth/callback# OIDC_SCOPES=openid profile email# OIDC_USERINFO_ENDPOINT=https://graph.microsoft.com/oidc/userinfo